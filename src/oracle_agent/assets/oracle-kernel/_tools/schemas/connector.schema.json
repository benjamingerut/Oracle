{
  "title": "connector_manifest",
  "description": "A connector manifest (Connectors/<id>/<id>.manifest.yaml). locality says where the bytes physically live; capture_tier says how much we copy. Runtime contract: Connector.pull/probe/freshness/health.",
  "type": "object",
  "required": [
    "id",
    "system",
    "status",
    "access_mode",
    "locality",
    "capture_tier",
    "auth",
    "permissions",
    "freshness"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "system": {
      "type": "string",
      "pattern": "\\S"
    },
    "status": {
      "type": "string",
      "enum": [
        "planned",
        "active",
        "degraded",
        "broken",
        "deprecated"
      ]
    },
    "access_mode": {
      "type": "string",
      "enum": [
        "api",
        "mcp",
        "cli",
        "file_drop",
        "database",
        "manual",
        "repo",
        "folder"
      ]
    },
    "locality": {
      "type": "string",
      "enum": [
        "external_only",
        "snapshot_local",
        "mirror_local"
      ]
    },
    "capture_tier": {
      "type": "string",
      "enum": [
        "manifest_only",
        "snapshot",
        "mirror"
      ]
    },
    "auth": {
      "type": "object",
      "required": [
        "method"
      ],
      "properties": {
        "method": {
          "type": "string"
        },
        "vars": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "permissions": {
      "type": "string",
      "enum": [
        "read_only",
        "read_write",
        "unknown"
      ]
    },
    "freshness": {
      "type": "object",
      "required": [
        "class"
      ],
      "properties": {
        "class": {
          "type": "string"
        },
        "last_verified": {
          "type": "string"
        },
        "expected_decay_days": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "source": {
      "type": "object",
      "description": "Per-connector scope allowlist + pull policy. The schema's job is SHAPE/TYPO detection: unknown keys fail (additionalProperties: false) but empty/None values VALIDATE -- the template legitimately ships a bare 'key:'. Emptiness is enforced at PULL time by the default-deny allowlist gate: None/missing/[]/non-list all refuse (empty never means 'everything'; P7S-13). API base URLs are pinned in connector code, never here (P7S-5) -- the only manifest-supplied endpoint is the IMAP host.",
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": ["string", "null"]
        },
        "default_sensitivity": {
          "type": ["string", "null"],
          "enum": [
            "public",
            "internal",
            "confidential",
            "restricted",
            "secret",
            null
          ]
        },
        "max_files": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "max_bytes": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "cadence": {
          "type": ["string", "null"],
          "pattern": "^(hourly|daily|weekly|[0-9]+h|[0-9]+d)$"
        },
        "folder_ids": {
          "type": ["array", "null"],
          "items": {
            "type": "string"
          }
        },
        "sites": {
          "type": ["array", "null"],
          "items": {
            "type": "string"
          }
        },
        "drives": {
          "type": ["array", "null"],
          "items": {
            "type": "string"
          }
        },
        "page_ids": {
          "type": ["array", "null"],
          "items": {
            "type": "string"
          }
        },
        "database_ids": {
          "type": ["array", "null"],
          "items": {
            "type": "string"
          }
        },
        "host": {
          "type": ["string", "null"]
        },
        "folders": {
          "type": ["array", "null"],
          "items": {
            "type": "string"
          }
        },
        "since_days": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "channels": {
          "type": ["array", "null"],
          "items": {
            "type": "string"
          }
        }
      }
    },
    "schema": {
      "type": "object",
      "properties": {
        "map_location": {
          "type": "string"
        },
        "key_objects": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "join_keys": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "authoritative_for": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "corroborates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "cannot_prove": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forbidden_uses": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "biases": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "health_check": {
      "type": "object",
      "properties": {
        "cadence": {
          "type": "string"
        },
        "checks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "schema_refresh": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "cadence": {
          "type": "string"
        },
        "remote_probe": {
          "type": "boolean"
        }
      }
    }
  }
}
