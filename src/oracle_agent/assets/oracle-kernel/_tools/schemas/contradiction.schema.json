{
  "title": "contradiction",
  "description": "An active unresolved conflict among claims, sources, models, or metrics. First-class because unresolved conflicts often point to the most valuable truths; the oracle preserves contradictions rather than averaging decision-relevant mismatches away.",
  "type": "object",
  "required": [
    "id",
    "type",
    "title",
    "created",
    "updated",
    "sensitivity",
    "status",
    "tags",
    "severity",
    "claims_in_conflict",
    "decision_relevance"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "\\S"
    },
    "type": {
      "type": "string",
      "enum": [
        "contradiction"
      ]
    },
    "title": {
      "type": "string",
      "pattern": "\\S"
    },
    "created": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}"
    },
    "updated": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}"
    },
    "sensitivity": {
      "type": "string",
      "enum": [
        "public",
        "internal",
        "confidential",
        "restricted",
        "secret"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "investigating",
        "resolved",
        "accepted_residual",
        "superseded"
      ]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "actor": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "classification": {
      "type": "string",
      "enum": [
        "must_resolve",
        "bounded_residual",
        "watch",
        "schema_debt"
      ]
    },
    "claims_in_conflict": {
      "type": "string",
      "pattern": "\\S"
    },
    "possible_causes": {
      "type": "string"
    },
    "resolution_plan": {
      "type": "string"
    },
    "resolving_source": {
      "type": "string"
    },
    "decision_relevance": {
      "type": "string",
      "pattern": "\\S"
    },
    "supersedes": {
      "type": "string"
    },
    "superseded_by": {
      "type": "string"
    },
    "content_sha256": {
      "type": "string"
    }
  }
}
