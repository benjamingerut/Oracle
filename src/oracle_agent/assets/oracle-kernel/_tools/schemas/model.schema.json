{
  "title": "model",
  "description": "The current best explanatory compression of business reality. A model must predict: a core_claim, explicit predictions, and a review cadence with a next_review date so it is held accountable to reality over time.",
  "type": "object",
  "required": [
    "id",
    "type",
    "title",
    "created",
    "updated",
    "sensitivity",
    "status",
    "tags",
    "core_claim",
    "predictions",
    "review_cadence",
    "next_review"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "\\S"
    },
    "type": {
      "type": "string",
      "enum": [
        "model"
      ]
    },
    "title": {
      "type": "string",
      "pattern": "\\S"
    },
    "created": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}"
    },
    "updated": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}"
    },
    "sensitivity": {
      "type": "string",
      "enum": [
        "public",
        "internal",
        "confidential",
        "restricted",
        "secret"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "challenged",
        "superseded"
      ]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "actor": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "scope": {
      "type": "string"
    },
    "core_claim": {
      "type": "string",
      "pattern": "\\S"
    },
    "explains": {
      "type": "string"
    },
    "known_residuals": {
      "type": "string"
    },
    "predictions": {
      "type": "string",
      "pattern": "\\S"
    },
    "review_cadence": {
      "type": "string",
      "pattern": "\\S"
    },
    "next_review": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}"
    },
    "supersedes": {
      "type": "string"
    },
    "superseded_by": {
      "type": "string"
    },
    "content_sha256": {
      "type": "string"
    }
  }
}
