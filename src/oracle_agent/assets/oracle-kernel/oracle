#!/usr/bin/env python3
"""Root-local Oracle CLI wrapper.

Usage:
    ./oracle <group> <cmd> [args...]

The wrapper keeps the Oracle CLI portable with the root directory. It does not
require a user-level PATH entry, shell alias, or machine-specific install path.
"""
from __future__ import annotations

import os
import sys
from pathlib import Path


def main(argv: list[str] | None = None) -> int:
    root = Path(__file__).resolve().parent
    os.chdir(root)

    tools_dir = root / "_tools"
    if str(tools_dir) not in sys.path:
        sys.path.insert(0, str(tools_dir))

    try:
        import oracle_cli  # type: ignore
    except Exception as exc:
        sys.stderr.write(f"oracle: could not import _tools/oracle_cli.py: {exc}\n")
        return 3

    args = sys.argv[1:] if argv is None else argv
    result = oracle_cli.main(args)
    return int(result) if isinstance(result, int) else 0


if __name__ == "__main__":
    raise SystemExit(main())
